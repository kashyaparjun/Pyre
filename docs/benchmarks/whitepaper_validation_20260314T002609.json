  "claims": [
    {
      "claim_id": "E1",
      "quote": "The bridge round-trip for a typical agent message (under 1KB of state) adds 0.1-0.3ms of latency.",
      "claim_class": "empirical",
      "evidence_type": "benchmark",
      "metric": "bridge.uds.small.p50_ms and bridge.uds.small.p99_ms",
      "threshold": "validated if p50 in [0.1,0.3] and p99 <= 0.5",
      "partial_rule": "partial if p50 <= 0.5 and p99 <= 1.0",
      "caveats": "Requires UDS benchmark transport source.",
      "required_profile": "rigorous",
      "transport_required": "uds",
      "suite_keys": [
        "bridge_suite"
      ],
      "class": "empirical"
    },
    {
      "claim_id": "E2",
      "quote": "The Unix domain socket bridge supports 50,000-100,000 messages per second.",
      "claim_class": "empirical",
      "evidence_type": "benchmark",
      "metric": "bridge.uds.small.messages_per_second",
      "threshold": "validated if median >= 50000",
      "partial_rule": "partial if median >= 10000",
      "caveats": "UDS source of truth only.",
      "required_profile": "rigorous",
      "transport_required": "uds",
      "suite_keys": [
        "bridge_suite"
      ],
      "class": "empirical"
    },
    {
      "claim_id": "E3",
      "quote": "Booting the Elixir runtime adds 500-1000ms to application startup.",
      "claim_class": "empirical",
      "evidence_type": "benchmark",
      "metric": "startup.boot_ms median",
      "threshold": "validated if median in [500,1000]",
      "partial_rule": "partial if median in [300,1500]",
      "caveats": "Local workstation variance expected.",
      "required_profile": "rigorous",
      "transport_required": "none",
      "suite_keys": [
        "startup_overhead"
      ],
      "class": "empirical"
    },
    {
      "claim_id": "E4",
      "quote": "Supervisors restart child processes when they fail with one_for_one, one_for_all, and rest_for_one semantics.",
      "claim_class": "empirical",
      "evidence_type": "integration_test",
      "metric": "recovery.restart_success_ratio and strategy checks",
      "threshold": "validated if ratio >= 0.99 and all checks pass",
      "partial_rule": "partial if ratio >= 0.90 and 2/3 checks pass",
      "caveats": "Bridge recovery checks over Elixir runtime.",
      "required_profile": "quick",
      "transport_required": "tcp",
      "suite_keys": [
        "failure_recovery"
      ],
      "class": "empirical"
    },
    {
      "claim_id": "E5",
      "quote": "The Elixir runtime adds approximately 30MB of base memory and each agent on the Elixir side consumes 2-5KB.",
      "claim_class": "empirical",
      "evidence_type": "benchmark",
      "metric": "memory_scaling.elixir.base_runtime_bytes and bytes_per_agent",
      "threshold": "validated if base in [20,45]MB and slope in [2,5]KB",
      "partial_rule": "partial if base in [15,60]MB and slope <= 10KB",
      "caveats": "RSS is allocator/platform dependent.",
      "required_profile": "rigorous",
      "transport_required": "none",
      "suite_keys": [
        "memory_scaling"
      ],
      "class": "empirical"
    },
    {
      "claim_id": "E6",
